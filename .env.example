# Environment Variables Configuration
# Copy this to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database (when you add one)
DATABASE_URL=

# API Keys (when you add real platform integrations)
SWIGGY_API_KEY=
ZOMATO_API_KEY=
BLINKIT_API_KEY=
ZEPTO_API_KEY=

# Google Maps API (optional, for better geocoding)
GOOGLE_MAPS_API_KEY=

# Deployment URL (will be auto-set)
API_URL=http://localhost:5000/api
