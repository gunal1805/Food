# Environment Configuration for GGS Boys Backend

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==================== AMAZON PRODUCT ADVERTISING API ====================
# Get these from: https://advertising.amazon.com/API
AMAZON_API_KEY=your_amazon_api_key
AMAZON_API_SECRET=your_amazon_api_secret
AMAZON_ASSOCIATE_TAG=your_associate_tag
AMAZON_REGION=IN

# ==================== FLIPKART AFFILIATE API ====================
# Get these from: https://www.flipkart.com/affiliate
FLIPKART_API_KEY=your_flipkart_api_key
FLIPKART_AFFILIATE_ID=your_affiliate_id

# ==================== DATABASE (Optional) ====================
# For MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ggs-boys
MONGODB_DB_NAME=ggs-boys

# ==================== AWS Configuration ====================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ==================== CACHE ====================
CACHE_TTL=3600
PRICE_UPDATE_INTERVAL=86400
